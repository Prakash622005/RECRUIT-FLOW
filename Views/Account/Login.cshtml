@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<!-- Custom Styles for the Professional Black-Violet Aesthetic -->
<style>
    body {
        background: radial-gradient(circle at 50% 50%, #1a0b2e 0%, #0a0512 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        color: #f1f1f1;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .login-container {
        background: rgba(20, 10, 35, 0.65);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(138, 43, 226, 0.2);
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), 
                    0 0 25px rgba(138, 43, 226, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .login-container:hover {
        border-color: rgba(138, 43, 226, 0.4);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6), 
                    0 0 35px rgba(138, 43, 226, 0.2);
    }

    .brand-title {
        background: linear-gradient(135deg, #ffffff 0%, #c79eff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 700;
        letter-spacing: -0.5px;
    }

    .form-label {
        color: #d1c4e9;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #ffffff;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        transition: all 0.2s ease-in-out;
    }

    .form-control:focus {
        background-color: rgba(255, 255, 255, 0.08);
        border-color: #8a2be2;
        color: #ffffff;
        box-shadow: 0 0 0 4px rgba(138, 43, 226, 0.25);
    }

    /* Auto-fill styling for dark input backgrounds */
    .form-control:-webkit-autofill,
    .form-control:-webkit-autofill:hover,
    .form-control:-webkit-autofill:focus {
        -webkit-text-fill-color: #ffffff;
        -webkit-box-shadow: 0 0 0px 1000px #1e1233 inset;
        transition: background-color 5000s ease-in-out 0s;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #8a2be2 0%, #6a0dad 100%);
        border: none;
        color: white;
        padding: 0.75rem;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .btn-gradient:hover {
        background: linear-gradient(135deg, #9933ff 0%, #7a1fa2 100%);
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 15px rgba(138, 43, 226, 0.4);
    }

    .btn-gradient:active {
        transform: translateY(1px);
    }

    .text-violet-link {
        color: #c79eff;
        text-decoration: none;
        transition: color 0.2s ease;
        font-weight: 500;
    }

    .text-violet-link:hover {
        color: #e0ccff;
        text-decoration: underline;
    }

    .text-muted-custom {
        color: #a194b8 !important;
    }

    .recruiter-box {
        background-color: rgba(138, 43, 226, 0.08);
        border-left: 3px solid #8a2be2;
        border-radius: 4px;
        padding: 0.75rem;
    }
</style>

<div class="container">
    <div class="row justify-content-center w-100 m-0">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4 login-container">
        <!-- App Name Top Center -->
<!-- <div style="position: absolute; top: -30px; left: 50%; transform: translateX(-50%); text-align: center; width: 100%; z-index: 10;">
    <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: 1.5px; margin: 0; background: linear-gradient(135deg, #ffffff 30%, #c79eff 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; drop-shadow: 0 2px 10px rgba(138, 43, 226, 0.3);">
        RecruitFlow
    </h1>
</div> -->
            
            <div class="text-center mb-4">
                <h2 class="brand-title mb-1">Welcome Back</h2>
                <p class="text-muted-custom small">Please enter your details to sign in</p>
            </div>

            <form asp-controller="Account" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UsernameOrEmail" class="form-label"></label>
                    <input asp-for="UsernameOrEmail" class="form-control" placeholder="Enter username or email" autocomplete="username" />
                    <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-gradient w-100 mb-3">Sign In</button>
            </form>

            <div class="text-center mb-4">
                <p class="mb-0 small text-muted-custom">
                    New applicant? <a asp-controller="Account" asp-action="Register" class="text-violet-link">Register here</a>
                </p>
            </div>

            <div class="recruiter-box">
                <p class="text-muted-custom small mb-0 d-flex align-items-center">
                    <i class="me-2 text-violet-link">⚡</i>
                    <span><strong>Recruiters:</strong> Sign in with the company credentials provided to you.</span>
                </p>
            </div>

        </div>
    </div>
</div>