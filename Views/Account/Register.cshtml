@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: radial-gradient(circle at 50% 50%, #1a0b2e 0%, #0a0512 100%);
        min-height: 100vh;
        color: #f1f1f1;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-container {
        max-width: 500px;
        width: 100%;
        padding: 15px;
    }

    .brand-title-center {
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -1px;
        background: linear-gradient(135deg, #ffffff 0%, #c79eff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 30px rgba(138, 43, 226, 0.3);
    }

    .auth-card {
        background: rgba(20, 10, 35, 0.65);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(138, 43, 226, 0.2);
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4), 0 0 25px rgba(138, 43, 226, 0.05);
    }

    .form-label {
        color: #d1c4e9;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.15) !important;
        color: #ffffff !important;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        transition: all 0.2s ease-in-out;
    }

    .form-control:focus {
        background-color: rgba(255, 255, 255, 0.08) !important;
        border-color: #8a2be2 !important;
        box-shadow: 0 0 0 4px rgba(138, 43, 226, 0.25) !important;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #8a2be2 0%, #6a0dad 100%);
        border: none;
        color: white;
        padding: 0.75rem;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .btn-gradient:hover {
        background: linear-gradient(135deg, #9933ff 0%, #7a1fa2 100%);
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 15px rgba(138, 43, 226, 0.4);
    }

    .link-violet {
        color: #c79eff;
        text-decoration: none;
        font-weight: 500;
    }

    .link-violet:hover {
        color: #ffffff;
    }
</style>

<div class="auth-container mx-auto">
    <!-- Project title positioned at top center -->
    <!-- <div class="text-center mb-4"> -->
        <!-- <h1 class="brand-title-center m-0">RecruitFlow</h1> -->
    <!-- </div> -->

    <div class="auth-card">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-white mb-1">Create Account</h3>
            <p class="text-muted small">Join us to manage or submit your applications</p>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <!-- Fixed property casing to match RegisterViewModel (FullName) -->
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-gradient w-100 mb-3">Register</button>

            <div class="text-center">
                <span class="text-muted small">Already have an account?</span>
                <a asp-controller="Account" asp-action="Login" class="link-violet small ms-1">Sign In</a>
            </div>
        </form>
    </div>
</div>