@model List<JobApplication>
@{
    ViewData["Title"] = "Recruiter Dashboard";
}

<!-- Custom Styles for the Professional Black-Violet Dashboard Aesthetic -->
<style>
    /* Recruiter Table System Overrides */
.recruiter-table {
    background: #ffffff !important;
    border-color: rgba(138, 43, 226, 0.15) !important;
}

.recruiter-table thead th {
    background: linear-gradient(135deg, #25123e 0%, #140a24 100%) !important;
    color: #c79eff !important;
    font-weight: 600;
    border-bottom: 2px solid rgba(138, 43, 226, 0.3) !important;
    padding: 1rem 0.75rem;
}

/* Enforces black text color across all recruiter row actions, metadata, and strings */
.recruiter-table tbody tr, 
.recruiter-table tbody td,
.recruiter-table tbody td a:not(.btn) {
    background-color: #ffffff !important;
    color: #000000 !important; /* Fixed text color to deep black */
}

.recruiter-table tbody tr:hover td {
    background-color: rgba(138, 43, 226, 0.08) !important;
    color: #000000 !important;
}

.recruiter-table td {
    padding: 1rem 0.75rem !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1) !important;
}

/* --- Added Custom Badge Color States --- */
/* Selected State (Green) */
.recruiter-table tbody td .bg-custom-success {
    background-color: #d1e7dd !important;
    color: #0f5132 !important;
    border: 1px solid #badbcc;
}

/* Rejected State (Red) */
.recruiter-table tbody td .bg-custom-danger {
    background-color: #f8d7da !important;
    color: #842029 !important;
    border: 1px solid #f5c2c7;
}

/* Pending State (Yellow/Amber) */
.recruiter-table tbody td .bg-custom-pending {
    background-color: #fff3cd !important;
    color: #664d03 !important;
    border: 1px solid #ffecb5;
}
</style>

<div class="container py-2">
    <h3 class="dashboard-header mb-3">All Applications</h3>
    <div class="dashboard-card">
        <div class="table-responsive">
            <table class="table recruiter-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Applicant</th>
                        <th>Job Role</th>
                        <th>Experience</th>
                        <th>Current CTC</th>
                        <th>Expected CTC</th>
                        <th>Resume</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td class="fw-bold">@app.FullName</td>
                            <td>@app.JobRole</td>
                            <td>@app.ExperienceYears yr(s)</td>
                            <td>@app.CurrentCTC.ToString("N2")</td>
                            <td>@app.ExpectedCTC.ToString("N2")</td>
                            <td>
                                <a asp-controller="Company" asp-action="DownloadResume" asp-route-id="@app.Id" class="btn btn-sm btn-violet-outline">Download</a>
                            </td>
                            <td>
                                @{
                                    var badgeClass = app.Status switch
                                    {
                                        ApplicationStatus.SelectedForInterview => "bg-custom-success",
                                        ApplicationStatus.Rejected => "bg-custom-danger",
                                        _ => "bg-custom-pending"
                                    };
                                }
                                <span class="badge @badgeClass px-2.5 py-1.5 rounded">@app.Status</span>
                                @if (app.Status == ApplicationStatus.SelectedForInterview)
                                {
                                    <div class="small mt-1">
                                        @app.InterviewDate?.ToString("dd MMM yyyy") @app.InterviewTime<br />@app.InterviewVenue
                                    </div>
                                }
                            </td>
                            <td class="text-end">
                                @if (app.Status == ApplicationStatus.Pending)
                                {
                                    <button type="button" class="btn btn-sm btn-success mb-1" data-bs-toggle="modal" data-bs-target="#selectModal-@app.Id">Select</button>

                                    <form asp-controller="Company" asp-action="Reject" asp-route-id="@app.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Reject this applicant?');">
                                        <button type="submit" class="btn btn-sm btn-danger mb-1">Reject</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted-custom small">No action</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modals live OUTSIDE the table - a hidden ancestor row would keep them from ever being shown. *@
@foreach (var app in Model.Where(a => a.Status == ApplicationStatus.Pending))
{
    <div class="modal fade" id="selectModal-@app.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-controller="Company" asp-action="Select" asp-route-id="@app.Id" method="post">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Schedule Interview - @app.FullName</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Interview Date</label>
                            <input type="date" name="InterviewDate" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Interview Time</label>
                            <input type="time" name="InterviewTime" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Venue</label>
                            <input type="text" name="InterviewVenue" class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Confirm Selection</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}