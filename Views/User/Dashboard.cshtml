@model JobApplicationViewModel
@{
    ViewData["Title"] = "Applicant Dashboard";
    var history = ViewBag.History as List<JobApplication>;
}

<!-- Custom Styles for the Professional Black-Violet Dashboard Aesthetic -->
<style>
   /* Fixed Table Layout to Avoid Bootstrap White Background Overrides */
.custom-table {
    background: #ffffff !important; /* Forces the table container to remain clean white */
    border-color: rgba(138, 43, 226, 0.15) !important;
}

.custom-table thead th {
    background: linear-gradient(135deg, #25123e 0%, #140a24 100%) !important;
    color: #c79eff !important;
    font-weight: 600;
    border-bottom: 2px solid rgba(138, 43, 226, 0.3) !important;
    padding: 1rem 0.75rem;
}

/* Forces ALL inner cell text to be black and highly visible against the white background */
.custom-table tbody tr, 
.custom-table tbody td, 
.custom-table tbody td.fw-bold {
    background-color: #ffffff !important;
    color: #000000 !important; /* Fixed text color to deep black */
    transition: background-color 0.2s ease;
}

/* Subtle violet tint when hovering over a white row */
.custom-table tbody tr:hover td {
    background-color: rgba(138, 43, 226, 0.08) !important;
    color: #000000 !important;
}

.custom-table td {
    padding: 1rem 0.75rem !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1) !important;
}      

.btn-submit-theme {
    background: linear-gradient(135deg, #6a0dad 0%, #25123e 100%);
    border: 1px solid rgba(138, 43, 226, 0.4);
    color: #ffffff !important;
    padding: 0.75rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.2s ease-in-out;
    box-shadow: 0 4px 15px rgba(20, 10, 35, 0.2);
}

.btn-submit-theme:hover {
    background: linear-gradient(135deg, #8a2be2 0%, #4b0082 100%);
    color: #ffffff !important;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(138, 43, 226, 0.4);
    border-color: rgba(199, 158, 255, 0.6);
}

.btn-submit-theme:active {
    transform: translateY(1px);
}
/* Custom Status Badges matching the header/button aesthetic */
.badge-theme-selected {
    background: linear-gradient(135deg, #25123e 0%, #140a24 100%) !important;
    color: #c79eff !important;
    border: 1px solid rgba(138, 43, 226, 0.4) !important;
}

.badge-theme-pending {
    background: linear-gradient(135deg, #321c50 0%, #1a0e2e 100%) !important;
    color: #d8b8ff !important;
    border: 1px solid rgba(138, 43, 226, 0.25) !important;
    opacity: 0.85;
}
</style>

<div class="container py-2">
    <!-- Section: Submit Application -->
    <h3 class="dashboard-header mb-3">Submit a Job Application</h3>
    <div class="dashboard-card">
        <form asp-controller="User" asp-action="Apply" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="JobRole" class="form-label"></label>
                    <select asp-for="JobRole" class="form-select">
                        <option value="">-- Select Job Role --</option>
                        @foreach (var role in JobRoles.All)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="JobRole" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ExperienceYears" class="form-label"></label>
                    <input asp-for="ExperienceYears" class="form-control" type="number" min="0" placeholder="e.g. 2" />
                    <span asp-validation-for="ExperienceYears" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CurrentCTC" class="form-label"></label>
                    <input asp-for="CurrentCTC" class="form-control" type="number" step="0.01" placeholder="Current Package" />
                    <span asp-validation-for="CurrentCTC" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ExpectedCTC" class="form-label"></label>
                    <input asp-for="ExpectedCTC" class="form-control" type="number" step="0.01" placeholder="Expected Package" />
                    <span asp-validation-for="ExpectedCTC" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Resume" class="form-label"></label>
                    <input asp-for="Resume" class="form-control" type="file" accept=".pdf" />
                    <span asp-validation-for="Resume" class="text-danger small"></span>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                   <button type="submit" class="btn w-100" style="background: linear-gradient(135deg, #8a2be2 0%, #6a0dad 100%); border: 1px solid rgba(138, 43, 226, 0.4); color: #ffffff; padding: 0.75rem; font-weight: 600; border-radius: 8px; box-shadow: 0 4px 15px rgba(138, 43, 226, 0.3);">Submit Application</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Section: History -->
    <h3 class="dashboard-header mb-3">Your Application History</h3>
    <div class="dashboard-card">
        @if (history == null || !history.Any())
        {
            <p class="text-muted-custom mb-0">You haven't submitted any applications yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle custom-table mb-0">
                    <thead>
                        <tr>
                            <th>Job Role</th>
                            <th>Applied On</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in history)
                        {
                            <tr>
                                <td class="fw-bold text-black">@app.JobRole</td>
                                <td>@app.AppliedOn.ToString("dd MMM yyyy")</td>
                                <td>
    @{
        var badgeClass = app.Status switch
        {
            ApplicationStatus.SelectedForInterview => "badge-theme-selected",
            ApplicationStatus.Rejected => "bg-danger text-white", // Keeping standard Bootstrap danger for rejections so it stands out cleanly
            _ => "badge-theme-pending"
        };
    }
    <span class="badge @badgeClass px-2.5 py-1.5 rounded">@app.Status</span>
</td>
                                <td class="text-end">
                                    <a asp-controller="User" asp-action="Status" asp-route-id="@app.Id" class="btn btn-sm px-3" style="color: #c79eff; border: 1px solid rgba(138, 43, 226, 0.5); background: transparent; transition: all 0.2s ease;" onmouseover="this.style.background='linear-gradient(135deg, #25123e 0%, #140a24 100%)'; this.style.color='#ffffff';" onmouseout="this.style.background='transparent'; this.style.color='#6a00ff';">
    View Status
</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>